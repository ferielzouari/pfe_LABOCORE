# ─────────────────────────────────────────────
# Stage 1 — Install dependencies
# ─────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --frozen-lockfile

# ─────────────────────────────────────────────
# Stage 2 — Build the Vite / React app
# ─────────────────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app

# The backend URL is injected at build time so Vite bakes it into the bundle.
# Override with: docker build --build-arg VITE_API_URL=http://your-host:8080/api
ARG VITE_API_URL=http://localhost:8080/api
ENV VITE_API_URL=${VITE_API_URL}

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN npm run build
# Vite outputs to /app/dist

# ─────────────────────────────────────────────
# Stage 3 — Serve with Nginx (lightweight runtime)
# ─────────────────────────────────────────────
FROM nginx:1.27-alpine AS runner

# Remove default nginx page
RUN rm -rf /usr/share/nginx/html/*

# Copy compiled React assets
COPY --from=builder /app/dist /usr/share/nginx/html

# Custom nginx config: enables SPA routing (all paths → index.html)
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]